config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="Fairy Catch"
config/description="Catch em' apples."
run/main_scene="uid://bxwfq81j2m2sw"
config/features=PackedStringArray("4.6", "Mobile")
config/icon="uid://c0grhtgox0bm2"
config/windows_native_icon="res://assets/fcatch_icon.ico"

[autoload]

DifficultyManager="*res://src/DifficultyManager.gd"
GameManager="*res://src/game_manager.gd"
EventBus="*res://src/event_bus.gd"
Nodemusic="*res://scenes/nodemusic.tscn"
SFXManager="*res://scenes/SFXManager.tscn"

[display]

window/stretch/mode="viewport"

[dotnet]

project/assembly_name="Fairy Catch"

